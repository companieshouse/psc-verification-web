{% extends "layouts/default.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/details/macro.njk" import govukDetails %}

{% set title = i18n.individual_psc_list_main_title %}

{% block main_content %}

    <h1 class="govuk-heading-l">{{ i18n.individual_psc_list_main_title }}</h1>
    <p class="govuk-body">{{ i18n.individual_psc_list_overview }}</p>
    <h1 class="govuk-heading-m">{{ i18n.individaul_psc_list_description_title }}</h1>
    <p class="govuk-body">{{ i18n.individaul_psc_list_description }} <strong companyName </strong> {{  i18n.individual_psc_list_description1 }}</p>


    {% for pscCard in pscCardItems %}

    {% include "includes/pscSummaryCard.njk" %}
    
    {% endfor %}

    <h2 class="govuk-heading-m govuk-!-margin-top-7"> {{ i18n.individual_psc_list_cannot_provide_details_title }}</h2>
    <p class="govuk-body">{{ i18n.individual_psc_list_cannot_provide_details_description }} <strong companyName  </strong> {{  i18n.individual_psc_list_cannot_provide_details_description1 }} Date {{ i18n.individual_psc_list_cannot_provide_details_description2 }}</p>

    {{ govukDetails({
  summaryText: i18n.individual_psc_list_why_need_to_wait_title ,
  text: i18n.individual_psc_list_why_need_to_wait_description
}) }}

{{ govukDetails({
  summaryText: i18n.individual_psc_list_cant_find_psc_title ,
  text: i18n.individual_psc_list_cant_find_psc_description
}) }}


{% endblock %}
